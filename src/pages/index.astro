---
import BaseLayout from '../layouts/BaseLayout.astro';
import { listLinks } from '../lib/kv';

const kv = Astro.locals.runtime.env.KV;
const links = await listLinks(kv);
const modeLabels: Record<string, string> = {
  redirect_302: '302 跳转',
  redirect_301: '301 跳转',
  iframe: 'Iframe 嵌入',
  text: '纯文本',
  html: 'HTML',
};
---

<BaseLayout title="CF ShortURL - 管理后台">
  <div id="app">
    <header class="header">
      <div class="header-left">
        <h1>🔗 CF ShortURL</h1>
        <span class="subtitle">短链接管理系统</span>
      </div>
      <button id="createBtn" class="btn btn-primary">+ 新建短链接</button>
    </header>

    <div class="search-bar">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" id="searchInput" placeholder="搜索 slug 或目标 URL..." />
    </div>

    <div class="table-wrapper">
      <table class="links-table">
        <thead>
          <tr>
            <th>短链接</th>
            <th>目标 URL</th>
            <th>模式</th>
            <th class="col-num">访问</th>
            <th class="col-date">创建时间</th>
            <th class="col-actions">操作</th>
          </tr>
        </thead>
        <tbody id="linksBody">
          {links.length === 0 && (
            <tr><td colspan="6" class="empty-row">暂无短链接，点击右上角新建</td></tr>
          )}
          {links.map((link) => (
            <tr data-slug={link.slug}>
              <td><a href={"/" + link.slug} target="_blank" class="slug-link">/{link.slug}</a></td>
              <td class="url-cell" title={link.url}>{link.url}</td>
              <td><span class={"badge badge-" + link.mode}>{modeLabels[link.mode] || link.mode}</span></td>
              <td class="col-num">{link.visit_count}</td>
              <td class="col-date">{new Date(link.created_at).toLocaleDateString("zh-CN")}</td>
              <td class="col-actions">
                <button class="btn btn-sm btn-edit" data-action="edit" data-slug={link.slug}>编辑</button>
                <button class="btn btn-sm btn-delete" data-action="delete" data-slug={link.slug}>删除</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div id="modalOverlay" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modalTitle">新建短链接</h2>
        <button id="modalCloseBtn" class="modal-close">✕</button>
      </div>
      <form id="linkForm">
        <input type="hidden" id="formSlug" name="originalSlug">
        <div class="form-group">
          <label for="slugInput">短链 Slug</label>
          <div class="slug-row">
            <input type="text" id="slugInput" placeholder="留空自动生成" class="input" autocomplete="off">
            <button type="button" id="randomSlugBtn" class="btn btn-outline" title="随机生成">🎲</button>
          </div>
        </div>
        <div class="form-group">
          <label for="urlInput">目标 URL <span class="required">*</span></label>
          <input type="url" id="urlInput" required class="input" placeholder="https://example.com">
        </div>
        <div class="form-group">
          <label for="modeSelect">响应模式</label>
          <select id="modeSelect" class="input">
            <option value="redirect_302">302 临时跳转</option>
            <option value="redirect_301">301 永久跳转</option>
            <option value="iframe">Iframe 嵌入（隐藏转发）</option>
            <option value="html">返回 HTML / JS / CSS / JSON</option>
            <option value="text">返回纯文本</option>
          </select>
        </div>

        <div id="iframeFields" class="mode-fields hidden">
          <div class="form-group">
            <label for="titleInput">页面标题</label>
            <input type="text" id="titleInput" class="input" placeholder="Short URL">
          </div>
          <div class="form-group">
            <label for="jsInput">注入 JS 代码</label>
            <textarea id="jsInput" class="textarea" rows="4" placeholder="可选的 JavaScript 代码，例如：&#10;console.log('hello');"></textarea>
          </div>
        </div>

        <div id="contentFields" class="mode-fields hidden">
          <div class="form-group">
            <label for="contentInput">返回内容</label>
            <textarea id="contentInput" class="textarea textarea-code" rows="8" placeholder="输入返回的内容（HTML / JS / CSS / JSON / 纯文本等）"></textarea>
          </div>
          <div class="form-group">
            <label for="contentTypeInput">Content-Type</label>
            <input type="text" id="contentTypeInput" class="input" placeholder="text/html（默认）">
            <span class="field-hint">例如: text/html, application/javascript, application/json, text/css, text/plain</span>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" id="cancelBtn" class="btn btn-outline">取消</button>
          <button type="submit" id="submitBtn" class="btn btn-primary">保存</button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .header-left h1 {
    font-size: 24px;
    font-weight: 700;
  }
  .subtitle {
    font-size: 14px;
    color: #999;
    margin-left: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all .15s;
  }
  .btn-primary {
    background: #1677ff;
    color: white;
    border-color: #1677ff;
  }
  .btn-primary:hover { background: #4096ff; }
  .btn-outline {
    background: white;
    color: #333;
    border-color: #d9d9d9;
  }
  .btn-outline:hover { border-color: #1677ff; color: #1677ff; }
  .btn-sm { padding: 4px 12px; font-size: 13px; }

  .search-bar {
    position: relative;
    margin-bottom: 16px;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: #999;
  }
  #searchInput {
    width: 100%;
    padding: 10px 12px 10px 38px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    font-size: 14px;
    outline: none;
    transition: border-color .15s;
  }
  #searchInput:focus { border-color: #1677ff; box-shadow: 0 0 0 2px rgba(22,119,255,0.1); }

  .table-wrapper {
    background: white;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    overflow-x: auto;
  }
  .links-table {
    width: 100%;
    border-collapse: collapse;
  }
  .links-table th {
    text-align: left;
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 600;
    color: #666;
    border-bottom: 1px solid #f0f0f0;
    white-space: nowrap;
  }
  .links-table td {
    padding: 12px 16px;
    font-size: 14px;
    border-bottom: 1px solid #f0f0f0;
  }
  .links-table tr:hover td { background: #fafafa; }
  .col-num { width: 60px; text-align: center; }
  .col-date { width: 100px; white-space: nowrap; }
  .col-actions { width: 140px; white-space: nowrap; }

  .slug-link {
    color: #1677ff;
    text-decoration: none;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-weight: 500;
  }
  .slug-link:hover { text-decoration: underline; }

  .url-cell {
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #666;
  }

  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-redirect_302 { background: #e6f4ff; color: #1677ff; }
  .badge-redirect_301 { background: #f6ffed; color: #52c41a; }
  .badge-iframe { background: #fff7e6; color: #fa8c16; }
  .badge-text { background: #f5f5f5; color: #666; }
  .badge-html { background: #f9f0ff; color: #722ed1; }

  .empty-row { text-align: center; color: #999; padding: 40px 16px !important; }

  .btn-edit { margin-right: 6px; color: #1677ff; border-color: #1677ff; }
  .btn-edit:hover { background: #e6f4ff; }
  .btn-delete { color: #ff4d4f; border-color: #ff4d4f; }
  .btn-delete:hover { background: #fff2f0; }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 60px;
    z-index: 1000;
  }
  .modal-overlay.hidden { display: none; }

  .modal {
    background: white;
    border-radius: 12px;
    width: 560px;
    max-width: calc(100vw - 40px);
    max-height: calc(100vh - 80px);
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px 0;
  }
  .modal-header h2 { font-size: 18px; font-weight: 600; }
  .modal-close {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: #999;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .modal-close:hover { background: #f5f5f5; color: #333; }

  #linkForm { padding: 20px 24px 24px; }
  .form-group { margin-bottom: 16px; }
  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 6px;
    color: #333;
  }
  .required { color: #ff4d4f; }
  .input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    transition: border-color .15s;
  }
  .input:focus { border-color: #1677ff; box-shadow: 0 0 0 2px rgba(22,119,255,0.1); }
  .textarea {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    resize: vertical;
    font-family: inherit;
    transition: border-color .15s;
  }
  .textarea:focus { border-color: #1677ff; box-shadow: 0 0 0 2px rgba(22,119,255,0.1); }
  .textarea-code { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px; }
  .field-hint { display: block; font-size: 12px; color: #999; margin-top: 4px; }

  .slug-row {
    display: flex;
    gap: 8px;
  }
  .slug-row .input { flex: 1; }

  .mode-fields { border-top: 1px solid #f0f0f0; padding-top: 16px; margin-top: 4px; }
  .mode-fields.hidden { display: none; }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid #f0f0f0;
    margin-top: 16px;
  }

  select.input { appearance: auto; }
</style>

<script>
(function () {
  const tbody = document.getElementById('linksBody');
  const searchInput = document.getElementById('searchInput');
  const createBtn = document.getElementById('createBtn');
  const modalOverlay = document.getElementById('modalOverlay');
  const modalCloseBtn = document.getElementById('modalCloseBtn');
  const cancelBtn = document.getElementById('cancelBtn');
  const modalTitle = document.getElementById('modalTitle');
  const submitBtn = document.getElementById('submitBtn');
  const linkForm = document.getElementById('linkForm');

  const formSlug = document.getElementById('formSlug');
  const slugInput = document.getElementById('slugInput');
  const urlInput = document.getElementById('urlInput');
  const modeSelect = document.getElementById('modeSelect');
  const titleInput = document.getElementById('titleInput');
  const jsInput = document.getElementById('jsInput');
  const contentInput = document.getElementById('contentInput');
  const contentTypeInput = document.getElementById('contentTypeInput');
  const randomSlugBtn = document.getElementById('randomSlugBtn');
  const iframeFields = document.getElementById('iframeFields');
  const contentFields = document.getElementById('contentFields');

  let editing = false;

  const MODE_FIELDS = {
    iframe: 'iframe',
    html: 'content',
    text: 'content',
  };

  function getMode() { return modeSelect.value; }

  function updateModeFields() {
    const mode = getMode();
    const fieldType = MODE_FIELDS[mode];
    iframeFields.classList.toggle('hidden', fieldType !== 'iframe');
    contentFields.classList.toggle('hidden', fieldType !== 'content');

    if (fieldType === 'content') {
      contentTypeInput.placeholder = mode === 'html' ? 'text/html（默认）' : 'text/plain（默认）';
    }
  }

  modeSelect.addEventListener('change', updateModeFields);

  function generateSlug(len) {
    const chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let slug = '';
    for (let i = 0; i < len; i++) slug += chars.charAt(Math.floor(Math.random() * chars.length));
    return slug;
  }

  randomSlugBtn.addEventListener('click', function () {
    slugInput.value = generateSlug(6);
  });

  async function loadLinks(search) {
    const url = search ? '/api/links?search=' + encodeURIComponent(search) : '/api/links';
    const res = await fetch(url);
    const links = await res.json();
    renderLinks(links);
  }

  const MODE_LABELS = {
    redirect_302: '302 跳转',
    redirect_301: '301 跳转',
    iframe: 'Iframe 嵌入',
    text: '纯文本',
    html: 'HTML',
  };

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderLinks(links) {
    if (links.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="empty-row">暂无短链接</td></tr>';
      return;
    }
    tbody.innerHTML = links.map(function (link) {
      return '<tr data-slug="' + escapeHtml(link.slug) + '">' +
        '<td><a href="/' + escapeHtml(link.slug) + '" target="_blank" class="slug-link">/' + escapeHtml(link.slug) + '</a></td>' +
        '<td class="url-cell" title="' + escapeHtml(link.url) + '">' + escapeHtml(link.url) + '</td>' +
        '<td><span class="badge badge-' + link.mode + '">' + (MODE_LABELS[link.mode] || link.mode) + '</span></td>' +
        '<td class="col-num">' + link.visit_count + '</td>' +
        '<td class="col-date">' + new Date(link.created_at).toLocaleDateString('zh-CN') + '</td>' +
        '<td class="col-actions">' +
        '<button class="btn btn-sm btn-edit" data-action="edit" data-slug="' + escapeHtml(link.slug) + '">编辑</button> ' +
        '<button class="btn btn-sm btn-delete" data-action="delete" data-slug="' + escapeHtml(link.slug) + '">删除</button>' +
        '</td></tr>';
    }).join('');

    tbody.querySelectorAll('[data-action="edit"]').forEach(function (btn) {
      btn.addEventListener('click', function () { openEditModal(btn.getAttribute('data-slug')); });
    });
    tbody.querySelectorAll('[data-action="delete"]').forEach(function (btn) {
      btn.addEventListener('click', function () { deleteLink(btn.getAttribute('data-slug')); });
    });
  }

  function openCreateModal() {
    editing = false;
    modalTitle.textContent = '新建短链接';
    submitBtn.textContent = '创建';
    linkForm.reset();
    formSlug.value = '';
    slugInput.value = '';
    titleInput.value = 'Short URL';
    contentTypeInput.value = '';
    updateModeFields();
    modalOverlay.classList.remove('hidden');
    urlInput.focus();
  }

  async function openEditModal(slug) {
    editing = true;
    modalTitle.textContent = '编辑短链接';
    submitBtn.textContent = '保存修改';

    const res = await fetch('/api/links?slug=' + encodeURIComponent(slug));
    const link = await res.json();

    formSlug.value = link.slug;
    slugInput.value = link.slug;
    urlInput.value = link.url;
    modeSelect.value = link.mode;
    titleInput.value = link.title || '';
    jsInput.value = link.inject_js || '';
    contentInput.value = link.content || '';
    contentTypeInput.value = link.content_type || '';

    updateModeFields();
    modalOverlay.classList.remove('hidden');
  }

  function closeModal() {
    modalOverlay.classList.add('hidden');
  }

  modalCloseBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);
  modalOverlay.addEventListener('click', function (e) {
    if (e.target === modalOverlay) closeModal();
  });

  linkForm.addEventListener('submit', async function (e) {
    e.preventDefault();

    const data = {
      slug: slugInput.value || undefined,
      url: urlInput.value,
      mode: modeSelect.value,
      title: titleInput.value || undefined,
      inject_js: jsInput.value || undefined,
      content: contentInput.value || undefined,
      content_type: contentTypeInput.value || undefined,
    };

    try {
      let res;
      if (editing) {
        data.slug = formSlug.value;
        res = await fetch('/api/links', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } else {
        res = await fetch('/api/links', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      }

      if (!res.ok) {
        const err = await res.json();
        alert('错误: ' + (err.error || '操作失败'));
        return;
      }

      closeModal();
      loadLinks(searchInput.value);
    } catch (err) {
      alert('网络错误: ' + err.message);
    }
  });

  async function deleteLink(slug) {
    if (!confirm('确定要删除 /' + slug + ' 吗？')) return;

    try {
      const res = await fetch('/api/links?slug=' + encodeURIComponent(slug), { method: 'DELETE' });
      if (!res.ok) {
        const err = await res.json();
        alert('删除失败: ' + (err.error || '未知错误'));
        return;
      }
      loadLinks(searchInput.value);
    } catch (err) {
      alert('网络错误: ' + err.message);
    }
  }

  createBtn.addEventListener('click', openCreateModal);

  let searchTimer;
  searchInput.addEventListener('input', function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function () {
      loadLinks(searchInput.value);
    }, 300);
  });
})();
</script>
