---
import BaseLayout from '../layouts/BaseLayout.astro';
import { listLinks } from '../lib/kv';
import { initAdmin, getSessionToken, validateSession } from '../lib/auth';

const kv = Astro.locals.runtime.env.KV;

await initAdmin(kv);

const token = getSessionToken(Astro.request);
const authed = token ? await validateSession(kv, token) : false;
if (!authed) {
  return Astro.redirect('/login', 302);
}

const result = await listLinks(kv, { limit: 20 });
const modeLabels: Record<string, string> = {
  redirect_302: '302 跳转', redirect_301: '301 跳转',
  iframe: 'Iframe 嵌入', text: '纯文本', html: 'HTML',
};
const hasAuth = (l: { basic_auth_username?: string; basic_auth_password?: string }) =>
  !!(l.basic_auth_username && l.basic_auth_password);
---

<BaseLayout title="CF ShortURL - 管理后台">
<div id="app">
  <header class="header">
    <div class="header-left">
      <h1>🔗 CF ShortURL</h1>
      <span class="subtitle">短链接管理</span>
    </div>
    <div class="header-actions">
      <button id="changePwdBtn" class="btn btn-outline">修改密码</button>
      <button id="logoutBtn" class="btn btn-outline btn-outline-danger">退出</button>
      <button id="createBtn" class="btn btn-primary">+ 新建</button>
    </div>
  </header>

  <div class="toolbar">
    <div class="search-row">
      <input type="text" id="searchInput" placeholder="搜索 slug 或目标 URL..." class="input search-input" />
      <select id="modeFilter" class="input filter-select">
        <option value="">全部模式</option>
        <option value="redirect_302">302 跳转</option>
        <option value="redirect_301">301 跳转</option>
        <option value="iframe">Iframe 嵌入</option>
        <option value="html">HTML / JS / JSON</option>
        <option value="text">纯文本</option>
      </select>
    </div>
  </div>

  <div class="table-wrap">
    <table class="links-table">
      <thead>
        <tr>
          <th>短链接</th>
          <th>目标 URL</th>
          <th class="col-mode">模式</th>
          <th class="col-auth">认证</th>
          <th class="col-num">访问</th>
          <th class="col-date">创建</th>
          <th class="col-actions">操作</th>
        </tr>
      </thead>
      <tbody id="linksBody">
        {result.links.length === 0 && (
        <tr><td colspan="7" class="empty-row">暂无短链接</td></tr>
        )}
        {result.links.map((link) => (
        <tr data-slug={link.slug}>
          <td><a href={"/" + link.slug} target="_blank" class="slug-link">/{link.slug}</a></td>
          <td class="url-cell" title={link.url}>{link.url}</td>
          <td class="col-mode"><span class={"badge badge-" + link.mode}>{modeLabels[link.mode] || link.mode}</span></td>
          <td class="col-auth">{hasAuth(link) ? <span class="badge badge-auth-on">🔒</span> : <span class="badge badge-auth-off">—</span>}</td>
          <td class="col-num">{link.visit_count}</td>
          <td class="col-date">{new Date(link.created_at).toLocaleDateString("zh-CN")}</td>
          <td class="col-actions">
            <button class="btn btn-xs btn-outline" data-action="edit" data-slug={link.slug}>编辑</button>
            <button class="btn btn-xs btn-outline-danger" data-action="delete" data-slug={link.slug}>删除</button>
          </td>
        </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div id="pagination" class="pagination hidden">
    <span id="pageInfo" class="page-info"></span>
    <div class="page-btns">
      <button id="prevBtn" class="btn btn-xs btn-outline" disabled>← 上一页</button>
      <button id="nextBtn" class="btn btn-xs btn-outline" disabled>下一页 →</button>
    </div>
  </div>
</div>

<!-- 新建/编辑 Modal -->
<div id="linkModalOverlay" class="modal-overlay hidden">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">新建短链接</h2>
      <button id="modalCloseBtn" class="modal-close">✕</button>
    </div>
    <form id="linkForm">
      <input type="hidden" id="formSlug">
      <div class="form-group">
        <label for="slugInput">短链 Slug</label>
        <div class="input-row">
          <input type="text" id="slugInput" placeholder="留空自动生成" class="input" autocomplete="off">
          <button type="button" id="randomSlugBtn" class="btn btn-outline" title="随机">🎲</button>
        </div>
      </div>
      <div class="form-group">
        <label for="urlInput">目标 URL <span class="required">*</span></label>
        <input type="url" id="urlInput" required class="input" placeholder="https://example.com">
      </div>
      <div class="form-group">
        <label for="modeSelect">响应模式</label>
        <select id="modeSelect" class="input">
          <option value="redirect_302">302 临时跳转</option>
          <option value="redirect_301">301 永久跳转</option>
          <option value="iframe">Iframe 嵌入（隐藏转发）</option>
          <option value="html">返回 HTML / JS / CSS / JSON</option>
          <option value="text">返回纯文本</option>
        </select>
      </div>
      <div id="iframeFields" class="mode-fields hidden">
        <div class="form-group">
          <label for="titleInput">页面标题</label>
          <input type="text" id="titleInput" class="input" placeholder="Short URL">
        </div>
        <div class="form-group">
          <label for="jsInput">注入 JS 代码</label>
          <textarea id="jsInput" class="textarea" rows="4" placeholder="可选的 JavaScript 代码"></textarea>
        </div>
      </div>
      <div id="contentFields" class="mode-fields hidden">
        <div class="form-group">
          <label for="contentInput">返回内容</label>
          <textarea id="contentInput" class="textarea textarea-code" rows="8" placeholder="HTML / JS / CSS / JSON / 纯文本"></textarea>
        </div>
        <div class="form-group">
          <label for="contentTypeInput">Content-Type</label>
          <input type="text" id="contentTypeInput" class="input" placeholder="text/html（默认）">
          <span class="hint">例如: application/json, application/javascript, text/css</span>
        </div>
      </div>
      <details class="auth-section">
        <summary class="auth-summary">🔒 BasicAuth 保护（可选）</summary>
        <div class="auth-fields">
          <div class="form-group">
            <label for="authUserInput">用户名</label>
            <input type="text" id="authUserInput" class="input" autocomplete="off">
          </div>
          <div class="form-group">
            <label for="authPassInput">密码</label>
            <input type="text" id="authPassInput" class="input" autocomplete="off">
          </div>
        </div>
      </details>
      <div class="form-actions">
        <button type="button" id="cancelBtn" class="btn btn-outline">取消</button>
        <button type="submit" id="submitBtn" class="btn btn-primary">保存</button>
      </div>
    </form>
  </div>
</div>

<!-- 删除确认 Modal -->
<div id="deleteModalOverlay" class="modal-overlay hidden">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2>确认删除</h2>
      <button id="deleteModalCloseBtn" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
      <p>确定要删除短链接 <strong id="deleteSlugDisplay"></strong> 吗？</p>
      <p class="hint">此操作不可恢复。</p>
    </div>
    <div class="form-actions" style="padding:0 24px 20px">
      <button id="deleteCancelBtn" class="btn btn-outline">取消</button>
      <button id="deleteConfirmBtn" class="btn btn-primary btn-danger-bg">删除</button>
    </div>
  </div>
</div>

<!-- 修改密码 Modal -->
<div id="pwdModalOverlay" class="modal-overlay hidden">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2>修改密码</h2>
      <button id="pwdModalCloseBtn" class="modal-close">✕</button>
    </div>
    <form id="pwdForm">
      <div class="form-group">
        <label for="oldPwdInput">原密码</label>
        <input type="password" id="oldPwdInput" class="input" autocomplete="current-password">
      </div>
      <div class="form-group">
        <label for="newPwdInput">新密码</label>
        <input type="password" id="newPwdInput" class="input" autocomplete="new-password">
      </div>
      <div class="form-group">
        <label for="confirmPwdInput">确认新密码</label>
        <input type="password" id="confirmPwdInput" class="input" autocomplete="new-password">
      </div>
      <p id="pwdErrorMsg" class="error-msg hidden"></p>
      <div class="form-actions">
        <button type="button" id="pwdCancelBtn" class="btn btn-outline">取消</button>
        <button type="submit" id="pwdSubmitBtn" class="btn btn-primary">修改</button>
      </div>
    </form>
  </div>
</div>

<!-- 退出确认 Modal -->
<div id="logoutModalOverlay" class="modal-overlay hidden">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2>退出登录</h2>
      <button id="logoutModalCloseBtn" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
      <p>确定退出登录吗？</p>
    </div>
    <div class="form-actions" style="padding:0 24px 20px">
      <button id="logoutCancelBtn" class="btn btn-outline">取消</button>
      <button id="logoutConfirmBtn" class="btn btn-primary btn-danger-bg">退出</button>
    </div>
  </div>
</div>
</BaseLayout>

<style>
  .header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; flex-wrap:wrap; gap:8px; }
  .header-left h1 { font-size:22px; font-weight:700; }
  .subtitle { font-size:13px; color:#999; margin-left:6px; }
  .header-actions { display:flex; gap:6px; flex-wrap:wrap; }

  .btn {
    display:inline-flex; align-items:center; justify-content:center; padding:7px 16px; border-radius:6px;
    font-size:13px; font-weight:500; cursor:pointer; border:1px solid transparent; transition:all .12s;
  }
  .btn-primary { background:#1677ff; color:#fff; border-color:#1677ff; }
  .btn-primary:hover { background:#4096ff; }
  .btn-primary:disabled { opacity:.5; cursor:not-allowed; }
  .btn-danger-bg { background:#ff4d4f; border-color:#ff4d4f; }
  .btn-danger-bg:hover { background:#ff7875; }
  .btn-outline { background:#fff; color:#333; border-color:#d9d9d9; }
  .btn-outline:hover { border-color:#1677ff; color:#1677ff; }
  .btn-outline-danger { color:#ff4d4f; }
  .btn-outline-danger:hover { border-color:#ff4d4f; background:#fff2f0; }
  .btn-xs { padding:3px 10px; font-size:12px; border-radius:4px; }

  .toolbar { margin-bottom:12px; }
  .search-row { display:flex; gap:8px; }
  .search-input { flex:1; }
  .filter-select { width:160px; flex-shrink:0; }
  .input {
    padding:8px 10px; border:1px solid #d9d9d9; border-radius:6px; font-size:13px;
    outline:none; transition:border-color .12s;
  }
  .input:focus { border-color:#1677ff; box-shadow:0 0 0 2px rgba(22,119,255,0.1); }

  .table-wrap { background:#fff; border-radius:8px; box-shadow:0 1px 3px rgba(0,0,0,.05); overflow-x:auto; }
  .links-table { width:100%; border-collapse:collapse; }
  .links-table th { text-align:left; padding:10px 12px; font-size:12px; font-weight:600; color:#888; border-bottom:1px solid #eee; white-space:nowrap; }
  .links-table td { padding:9px 12px; font-size:13px; border-bottom:1px solid #f5f5f5; }
  .links-table tr:last-child td { border-bottom:none; }
  .links-table tr:hover td { background:#fafafa; }
  .col-mode { width:100px; }
  .col-auth { width:50px; text-align:center; }
  .col-num { width:50px; text-align:center; }
  .col-date { width:80px; white-space:nowrap; }
  .col-actions { width:110px; white-space:nowrap; }

  .slug-link { color:#1677ff; text-decoration:none; font-family:'SF Mono','Fira Code',monospace; font-weight:500; font-size:12px; }
  .slug-link:hover { text-decoration:underline; }
  .url-cell { max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#666; font-size:12px; }
  .badge { display:inline-block; padding:1px 8px; border-radius:3px; font-size:11px; font-weight:500; }
  .badge-redirect_302 { background:#e6f4ff; color:#1677ff; }
  .badge-redirect_301 { background:#f6ffed; color:#52c41a; }
  .badge-iframe { background:#fff7e6; color:#fa8c16; }
  .badge-text { background:#f5f5f5; color:#666; }
  .badge-html { background:#f9f0ff; color:#722ed1; }
  .badge-auth-on { background:#fffbe6; color:#d4b106; font-size:11px; }
  .badge-auth-off { color:#ddd; font-size:12px; }
  .empty-row { text-align:center; color:#bbb; padding:32px 12px !important; font-size:13px; }

  .pagination { display:flex; justify-content:space-between; align-items:center; margin-top:12px; }
  .pagination.hidden { display:none; }
  .page-info { font-size:12px; color:#999; }
  .page-btns { display:flex; gap:6px; }

  .modal-overlay {
    position:fixed; inset:0; background:rgba(0,0,0,.4); display:flex; justify-content:center;
    align-items:flex-start; padding-top:60px; z-index:1000;
  }
  .modal-overlay.hidden { display:none; }
  .modal { background:#fff; border-radius:8px; width:540px; max-width:calc(100vw - 32px); max-height:calc(100vh - 80px); overflow-y:auto; box-shadow:0 4px 20px rgba(0,0,0,.12); }
  .modal-sm .modal { width:400px; }
  .modal-header { display:flex; justify-content:space-between; align-items:center; padding:16px 20px 0; }
  .modal-header h2 { font-size:16px; font-weight:600; }
  .modal-body { padding:16px 20px; font-size:14px; color:#333; }
  .modal-close { background:none; border:none; font-size:16px; cursor:pointer; color:#bbb; padding:2px 6px; border-radius:4px; }
  .modal-close:hover { background:#f5f5f5; color:#333; }

  #linkForm, #pwdForm { padding:16px 20px 20px; }
  .form-group { margin-bottom:14px; }
  .form-group label { display:block; font-size:13px; font-weight:500; margin-bottom:4px; color:#333; }
  .required { color:#ff4d4f; }
  .textarea {
    width:100%; padding:8px 10px; border:1px solid #d9d9d9; border-radius:6px; font-size:13px;
    outline:none; resize:vertical; font-family:inherit; transition:border-color .12s;
  }
  .textarea:focus { border-color:#1677ff; box-shadow:0 0 0 2px rgba(22,119,255,0.1); }
  .textarea-code { font-family:'SF Mono','Fira Code',monospace; font-size:12px; }
  .hint { display:block; font-size:11px; color:#bbb; margin-top:3px; }
  .error-msg { color:#ff4d4f; font-size:12px; margin-bottom:8px; }
  .error-msg.hidden { display:none; }

  .input-row { display:flex; gap:6px; }
  .input-row .input { flex:1; }

  .mode-fields { border-top:1px solid #eee; padding-top:14px; margin-top:2px; }
  .mode-fields.hidden { display:none; }

  .form-actions { display:flex; justify-content:flex-end; gap:6px; padding-top:14px; border-top:1px solid #eee; margin-top:14px; }

  .auth-section { margin-top:10px; border:1px solid #eee; border-radius:6px; padding:10px 14px; background:#fafafa; }
  .auth-summary { font-size:13px; font-weight:500; cursor:pointer; color:#555; }
  .auth-fields { margin-top:10px; }
  .auth-section[open] .auth-summary { margin-bottom:2px; }

  select.input { appearance:auto; }

  @media (max-width: 768px) {
    .header { flex-direction:column; align-items:stretch; }
    .header-actions { justify-content:flex-end; }
    .search-row { flex-direction:column; }
    .filter-select { width:100%; }
    .table-wrap { margin:0 -12px; border-radius:0; }
    .links-table th, .links-table td { padding:7px 8px; font-size:12px; }
    .links-table th:nth-child(4), .links-table td:nth-child(4),
    .links-table th:nth-child(5), .links-table td:nth-child(5),
    .links-table th:nth-child(6), .links-table td:nth-child(6) { display:none; }
    .url-cell { max-width:160px; }
    .col-actions { width:80px; }
    .modal-overlay { align-items:stretch; padding-top:0; }
    .modal, .modal-sm .modal { width:100%; max-width:100vw; max-height:100vh; border-radius:0; min-height:100vh; }
    #linkForm, #pwdForm { padding:12px 16px 16px; }
    .pagination { flex-direction:column; gap:8px; align-items:center; }
  }
</style>

<script>
(function () {
  // State
  let editing = false;
  let currentSlug = null;
  let page = 0;
  const PAGE_SIZE = 20;
  let totalItems = 0;

  // DOM refs
  const tbody = document.getElementById('linksBody');
  const searchInput = document.getElementById('searchInput');
  const modeFilter = document.getElementById('modeFilter');
  const createBtn = document.getElementById('createBtn');
  const changePwdBtn = document.getElementById('changePwdBtn');
  const logoutBtn = document.getElementById('logoutBtn');
  const pagination = document.getElementById('pagination');
  const pageInfo = document.getElementById('pageInfo');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  // Link modal
  const linkModalOverlay = document.getElementById('linkModalOverlay');
  const modalCloseBtn = document.getElementById('modalCloseBtn');
  const cancelBtn = document.getElementById('cancelBtn');
  const modalTitle = document.getElementById('modalTitle');
  const submitBtn = document.getElementById('submitBtn');
  const linkForm = document.getElementById('linkForm');
  const formSlug = document.getElementById('formSlug');
  const slugInput = document.getElementById('slugInput');
  const urlInput = document.getElementById('urlInput');
  const modeSelect = document.getElementById('modeSelect');
  const titleInput = document.getElementById('titleInput');
  const jsInput = document.getElementById('jsInput');
  const contentInput = document.getElementById('contentInput');
  const contentTypeInput = document.getElementById('contentTypeInput');
  const randomSlugBtn = document.getElementById('randomSlugBtn');
  const iframeFields = document.getElementById('iframeFields');
  const contentFields = document.getElementById('contentFields');
  const authUserInput = document.getElementById('authUserInput');
  const authPassInput = document.getElementById('authPassInput');

  // Delete modal
  const deleteModalOverlay = document.getElementById('deleteModalOverlay');
  const deleteModalCloseBtn = document.getElementById('deleteModalCloseBtn');
  const deleteCancelBtn = document.getElementById('deleteCancelBtn');
  const deleteConfirmBtn = document.getElementById('deleteConfirmBtn');
  const deleteSlugDisplay = document.getElementById('deleteSlugDisplay');

  // Password modal
  const pwdModalOverlay = document.getElementById('pwdModalOverlay');
  const pwdModalCloseBtn = document.getElementById('pwdModalCloseBtn');
  const pwdCancelBtn = document.getElementById('pwdCancelBtn');
  const pwdForm = document.getElementById('pwdForm');
  const oldPwdInput = document.getElementById('oldPwdInput');
  const newPwdInput = document.getElementById('newPwdInput');
  const confirmPwdInput = document.getElementById('confirmPwdInput');
  const pwdErrorMsg = document.getElementById('pwdErrorMsg');
  const pwdSubmitBtn = document.getElementById('pwdSubmitBtn');

  // Logout modal
  const logoutModalOverlay = document.getElementById('logoutModalOverlay');
  const logoutModalCloseBtn = document.getElementById('logoutModalCloseBtn');
  const logoutCancelBtn = document.getElementById('logoutCancelBtn');
  const logoutConfirmBtn = document.getElementById('logoutConfirmBtn');

  const MODE_FIELDS = { iframe:'iframe', html:'content', text:'content' };
  const MODE_LABELS = { redirect_302:'302 跳转', redirect_301:'301 跳转', iframe:'Iframe 嵌入', text:'纯文本', html:'HTML' };

  function getMode() { return modeSelect.value; }

  function updateModeFields() {
    const mode = getMode();
    const ft = MODE_FIELDS[mode];
    iframeFields.classList.toggle('hidden', ft !== 'iframe');
    contentFields.classList.toggle('hidden', ft !== 'content');
    if (ft === 'content') {
      contentTypeInput.placeholder = mode === 'html' ? 'text/html（默认）' : 'text/plain（默认）';
    }
  }
  modeSelect.addEventListener('change', updateModeFields);

  function genSlug(len) {
    const c = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let s = '';
    for (let i = 0; i < len; i++) s += c.charAt(Math.floor(Math.random() * c.length));
    return s;
  }
  randomSlugBtn.addEventListener('click', function () { slugInput.value = genSlug(6); });

  function esc(str) {
    var d = document.createElement('div'); d.textContent = str; return d.innerHTML;
  }

  function buildQuery() {
    var params = new URLSearchParams();
    params.set('offset', page * PAGE_SIZE);
    params.set('limit', PAGE_SIZE);
    if (searchInput.value) params.set('search', searchInput.value);
    if (modeFilter.value) params.set('mode', modeFilter.value);
    return params.toString();
  }

  async function loadLinks() {
    var res = await fetch('/api/links?' + buildQuery());
    var data = await res.json();
    totalItems = data.total;
    renderLinks(data.links);
    renderPagination();
  }

  function renderLinks(links) {
    if (!links || links.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="empty-row">暂无短链接</td></tr>';
      return;
    }
    tbody.innerHTML = links.map(function (link) {
      var ab = (link.basic_auth_username && link.basic_auth_password)
        ? '<span class="badge badge-auth-on">🔒</span>' : '<span class="badge badge-auth-off">—</span>';
      var modeLabel = MODE_LABELS[link.mode] || '未知';
      var modeClass = MODE_LABELS[link.mode] ? link.mode : '';
      return '<tr data-slug="' + esc(link.slug) + '">' +
        '<td><a href="/' + esc(link.slug) + '" target="_blank" class="slug-link">/' + esc(link.slug) + '</a></td>' +
        '<td class="url-cell" title="' + esc(link.url) + '">' + esc(link.url) + '</td>' +
        '<td class="col-mode"><span class="badge' + (modeClass ? ' badge-' + modeClass : '') + '">' + esc(modeLabel) + '</span></td>' +
        '<td class="col-auth">' + ab + '</td>' +
        '<td class="col-num">' + link.visit_count + '</td>' +
        '<td class="col-date">' + new Date(link.created_at).toLocaleDateString('zh-CN') + '</td>' +
        '<td class="col-actions">' +
        '<button class="btn btn-xs btn-outline" data-action="edit" data-slug="' + esc(link.slug) + '">编辑</button> ' +
        '<button class="btn btn-xs btn-outline-danger" data-action="delete" data-slug="' + esc(link.slug) + '">删除</button>' +
        '</td></tr>';
    }).join('');
    tbody.querySelectorAll('[data-action="edit"]').forEach(function (b) {
      b.addEventListener('click', function () { openEdit(b.getAttribute('data-slug')); });
    });
    tbody.querySelectorAll('[data-action="delete"]').forEach(function (b) {
      b.addEventListener('click', function () { openDelete(b.getAttribute('data-slug')); });
    });
  }

  function renderPagination() {
    var totalPages = Math.ceil(totalItems / PAGE_SIZE);
    if (totalPages <= 1) { pagination.classList.add('hidden'); return; }
    pagination.classList.remove('hidden');
    pageInfo.textContent = '共 ' + totalItems + ' 条，第 ' + (page + 1) + '/' + totalPages + ' 页';
    prevBtn.disabled = page <= 0;
    nextBtn.disabled = page >= totalPages - 1;
  }

  prevBtn.addEventListener('click', function () { if (page > 0) { page--; loadLinks(); } });
  nextBtn.addEventListener('click', function () { page++; loadLinks(); });

  // ---- Link modal ----
  function openCreate() {
    editing = false;
    modalTitle.textContent = '新建短链接';
    submitBtn.textContent = '创建';
    linkForm.reset();
    formSlug.value = '';
    slugInput.value = '';
    authUserInput.value = '';
    authPassInput.value = '';
    updateModeFields();
    linkModalOverlay.classList.remove('hidden');
    urlInput.focus();
  }

  async function openEdit(slug) {
    editing = true;
    modalTitle.textContent = '编辑短链接';
    submitBtn.textContent = '保存';
    var res = await fetch('/api/links?slug=' + encodeURIComponent(slug));
    var link = await res.json();
    formSlug.value = link.slug;
    slugInput.value = link.slug;
    urlInput.value = link.url;
    modeSelect.value = link.mode;
    titleInput.value = link.title || '';
    jsInput.value = link.inject_js || '';
    contentInput.value = link.content || '';
    contentTypeInput.value = link.content_type || '';
    authUserInput.value = link.basic_auth_username || '';
    authPassInput.value = link.basic_auth_password || '';
    updateModeFields();
    linkModalOverlay.classList.remove('hidden');
  }

  function closeLinkModal() { linkModalOverlay.classList.add('hidden'); }
  modalCloseBtn.addEventListener('click', closeLinkModal);
  cancelBtn.addEventListener('click', closeLinkModal);
  linkModalOverlay.addEventListener('click', function (e) { if (e.target === linkModalOverlay) closeLinkModal(); });

  linkForm.addEventListener('submit', async function (e) {
    e.preventDefault();
    var data = {
      slug: slugInput.value || undefined,
      url: urlInput.value,
      mode: modeSelect.value,
      title: titleInput.value || undefined,
      inject_js: jsInput.value || undefined,
      content: contentInput.value || undefined,
      content_type: contentTypeInput.value || undefined,
      basic_auth_username: authUserInput.value,
      basic_auth_password: authPassInput.value,
    };
    try {
      var res;
      if (editing) {
        data.slug = formSlug.value;
        res = await fetch('/api/links', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
      } else {
        res = await fetch('/api/links', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
      }
      if (!res.ok) {
        var err = await res.json();
        alert('错误: ' + (err.error || '操作失败')); return;
      }
      closeLinkModal();
      loadLinks();
    } catch (err) { alert('网络错误: ' + err.message); }
  });

  // ---- Delete modal ----
  function openDelete(slug) {
    currentSlug = slug;
    deleteSlugDisplay.textContent = '/' + slug;
    deleteModalOverlay.classList.remove('hidden');
  }
  function closeDeleteModal() { deleteModalOverlay.classList.add('hidden'); currentSlug = null; }
  deleteModalCloseBtn.addEventListener('click', closeDeleteModal);
  deleteCancelBtn.addEventListener('click', closeDeleteModal);
  deleteModalOverlay.addEventListener('click', function (e) { if (e.target === deleteModalOverlay) closeDeleteModal(); });

  deleteConfirmBtn.addEventListener('click', async function () {
    if (!currentSlug) return;
    try {
      var res = await fetch('/api/links?slug=' + encodeURIComponent(currentSlug), { method:'DELETE' });
      if (!res.ok) {
        var err = await res.json();
        alert('删除失败: ' + (err.error || '未知错误')); return;
      }
      closeDeleteModal();
      loadLinks();
    } catch (err) { alert('网络错误: ' + err.message); }
  });

  // ---- Password modal ----
  function openPwd() { pwdForm.reset(); pwdErrorMsg.classList.add('hidden'); pwdModalOverlay.classList.remove('hidden'); oldPwdInput.focus(); }
  function closePwd() { pwdModalOverlay.classList.add('hidden'); }
  changePwdBtn.addEventListener('click', openPwd);
  pwdModalCloseBtn.addEventListener('click', closePwd);
  pwdCancelBtn.addEventListener('click', closePwd);
  pwdModalOverlay.addEventListener('click', function (e) { if (e.target === pwdModalOverlay) closePwd(); });

  pwdForm.addEventListener('submit', async function (e) {
    e.preventDefault();
    pwdErrorMsg.classList.add('hidden');
    if (newPwdInput.value !== confirmPwdInput.value) {
      pwdErrorMsg.textContent = '两次密码不一致'; pwdErrorMsg.classList.remove('hidden'); return;
    }
    pwdSubmitBtn.disabled = true; pwdSubmitBtn.textContent = '修改中...';
    try {
      var res = await fetch('/api/change-password', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ oldPassword:oldPwdInput.value, newPassword:newPwdInput.value }) });
      if (res.ok) { alert('密码已修改'); closePwd(); }
      else { var d = await res.json(); pwdErrorMsg.textContent = d.error || '修改失败'; pwdErrorMsg.classList.remove('hidden'); }
    } catch { pwdErrorMsg.textContent = '网络错误'; pwdErrorMsg.classList.remove('hidden'); }
    finally { pwdSubmitBtn.disabled = false; pwdSubmitBtn.textContent = '修改'; }
  });

  // ---- Logout modal ----
  function openLogout() { logoutModalOverlay.classList.remove('hidden'); }
  function closeLogout() { logoutModalOverlay.classList.add('hidden'); }
  logoutBtn.addEventListener('click', openLogout);
  logoutModalCloseBtn.addEventListener('click', closeLogout);
  logoutCancelBtn.addEventListener('click', closeLogout);
  logoutModalOverlay.addEventListener('click', function (e) { if (e.target === logoutModalOverlay) closeLogout(); });
  logoutConfirmBtn.addEventListener('click', async function () {
    await fetch('/api/login', { method:'DELETE' });
    window.location.href = '/login';
  });

  // ---- Search / filter ----
  var searchTimer;
  searchInput.addEventListener('input', function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function () { page = 0; loadLinks(); }, 250);
  });
  modeFilter.addEventListener('change', function () { page = 0; loadLinks(); });

  // ---- Init ----
  createBtn.addEventListener('click', openCreate);
  loadLinks();
})();
</script>
